{
	"luci-app-singbox-manager": {
		"description": "Grant access to SingBox Manager",
		"read": {
			"ubus": {
				"singbox.manager": [ "status", "runtime_stats", "logs", "devices", "subscriptions", "nodes", "latency_test", "dns", "rulesets", "pac", "tproxy", "tun" ]
			},
			"uci": [ "singbox-manager" ]
		},
		"write": {
			"ubus": {
				"singbox.manager": [ "start", "stop", "restart", "reload", "validate", "manager_set_enabled", "subscription_set", "subscription_delete", "subscription_import", "refresh_subscription", "refresh_subscriptions", "node_set", "node_delete", "node_select", "node_ping_test", "node_latency_test", "health_check", "dns_profile_set", "dns_profile_delete", "dns_server_set", "dns_server_delete", "dns_test", "routing_profile_set", "routing_profile_delete", "ruleset_set", "ruleset_delete", "refresh_ruleset", "source_rule_set", "source_rule_delete", "pac_set", "pac_custom_set", "pac_custom_delete", "pac_custom_save" ]
			},
			"uci": [ "singbox-manager" ]
		}
	}
}

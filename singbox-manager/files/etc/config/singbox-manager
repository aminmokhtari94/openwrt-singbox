config manager 'main'
	option enabled '0'
	option log_level 'info'
	option active_group 'home'
	option runtime_mode 'rule'
	option sing_box_bin '/usr/bin/sing-box'
	option socket_path '/var/run/singbox-manager/singbox-managerd.sock'
	option api_listen '127.0.0.1:9090'
	option pac_listen '0.0.0.0:1088'
	option mixed_listen '0.0.0.0'
	option mixed_port '2080'
	option tproxy_port '7893'
	option dns_port '1053'
	option update_interval '24h'

config group 'home'
	option enabled '1'
	option name 'Home'
	list subscription 'example'
	option routing_profile 'iran_direct'
	option dns_profile 'split'
	option strategy 'urltest'
	option selected_node ''
	option health 'unknown'
	option latency_ms '0'
	option last_check ''

config subscription 'example'
	option enabled '0'
	option name 'Example'
	option url ''
	option format 'auto'
	option update_interval '24h'
	option last_update ''
	option health 'unknown'

config routing_profile 'iran_direct'
	option enabled '1'
	option name 'Iran Direct'
	option mode 'rule'
	list ruleset 'geoip-ir'
	list ruleset 'geosite-ir'
	option final 'proxy'

config routing_profile 'china_direct'
	option enabled '1'
	option name 'China Direct'
	option mode 'rule'
	list ruleset 'geoip-cn'
	list ruleset 'geosite-cn'
	option final 'proxy'

config routing_profile 'russia_direct'
	option enabled '1'
	option name 'Russia Direct'
	option mode 'rule'
	list ruleset 'geoip-ru'
	list ruleset 'geosite-ru'
	option final 'proxy'

config dns_profile 'split'
	option enabled '1'
	option name 'Split DNS'
	option mode 'split'
	list server 'cloudflare_doh'
	list server 'local_udp'
	option hijack '0'

config dns_server 'cloudflare_doh'
	option enabled '1'
	option name 'Cloudflare DoH'
	option type 'doh'
	option address 'https://1.1.1.1/dns-query'
	option detour 'proxy'

config dns_server 'google_doh'
	option enabled '0'
	option name 'Google DoH'
	option type 'doh'
	option address 'https://dns.google/dns-query'
	option detour 'proxy'

config dns_server 'quad9_dot'
	option enabled '0'
	option name 'Quad9 DoT'
	option type 'dot'
	option address 'tls://dns.quad9.net'
	option detour 'proxy'

config dns_server 'adguard_doh'
	option enabled '0'
	option name 'AdGuard DoH'
	option type 'doh'
	option address 'https://dns.adguard-dns.com/dns-query'
	option detour 'proxy'

config dns_server 'local_udp'
	option enabled '1'
	option name 'Local UDP'
	option type 'udp'
	option address '223.5.5.5'
	option detour 'direct'

config ruleset 'geoip_ir'
	option id 'geoip-ir'
	option enabled '1'
	option name 'GeoIP Iran'
	option type 'remote'
	option format 'srs'
	option url 'https://raw.githubusercontent.com/Chocolate4U/Iran-sing-box-rules/rule-set/geoip-ir.srs'
	option path '/etc/singbox-manager/rulesets/geoip-ir.srs'
	option update_interval '168h'
	option last_update ''
	option last_error ''

config ruleset 'geosite_ir'
	option id 'geosite-ir'
	option enabled '1'
	option name 'Geosite Iran'
	option type 'remote'
	option format 'srs'
	option url 'https://raw.githubusercontent.com/Chocolate4U/Iran-sing-box-rules/rule-set/geosite-ir.srs'
	option path '/etc/singbox-manager/rulesets/geosite-ir.srs'
	option update_interval '168h'
	option last_update ''
	option last_error ''

config ruleset 'geoip_cn'
	option id 'geoip-cn'
	option enabled '1'
	option name 'GeoIP China'
	option type 'remote'
	option format 'srs'
	option url 'https://raw.githubusercontent.com/SagerNet/sing-geoip/rule-set/geoip-cn.srs'
	option path '/etc/singbox-manager/rulesets/geoip-cn.srs'
	option update_interval '168h'
	option last_update ''
	option last_error ''

config ruleset 'geosite_cn'
	option id 'geosite-cn'
	option enabled '1'
	option name 'Geosite China'
	option type 'remote'
	option format 'srs'
	option url 'https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-geolocation-cn.srs'
	option path '/etc/singbox-manager/rulesets/geosite-cn.srs'
	option update_interval '168h'
	option last_update ''
	option last_error ''

config ruleset 'geoip_ru'
	option id 'geoip-ru'
	option enabled '1'
	option name 'GeoIP Russia'
	option type 'remote'
	option format 'srs'
	option url 'https://raw.githubusercontent.com/SagerNet/sing-geoip/rule-set/geoip-ru.srs'
	option path '/etc/singbox-manager/rulesets/geoip-ru.srs'
	option update_interval '168h'
	option last_update ''
	option last_error ''

config ruleset 'geosite_ru'
	option id 'geosite-ru'
	option enabled '1'
	option name 'Geosite Russia'
	option type 'remote'
	option format 'srs'
	option url 'https://raw.githubusercontent.com/runetfreedom/russia-v2ray-rules-dat/release/sing-box/rule-set-geosite/geosite-ru-available-only-inside.srs'
	option path '/etc/singbox-manager/rulesets/geosite-ru.srs'
	option update_interval '168h'
	option last_update ''
	option last_error ''

config pac 'pac'
	option enabled '0'
	option source 'generated'
	option selected_custom ''
	option local_bypass '1'
	list whitelist 'localhost'
	list whitelist '.lan'
	list blacklist ''
	list custom_rule ''

config tproxy 'tproxy'
	option enabled '0'
	list lan_ifname 'br-lan'
	list include_subnet ''
	list exclude_subnet '192.168.0.0/16'
	list include_mac ''
	option dns_hijack '0'
	option kill_switch '0'

config tun 'tun'
	option enabled '0'
	option auto_route '1'
	option auto_redirect '1'
	option inet4_address '172.19.0.1/30'
	option inet6_address 'fdfe:dcba:9876::1/126'

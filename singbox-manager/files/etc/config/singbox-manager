config manager 'main'
	option enabled '0'
	option log_level 'info'
	option active_group 'home'
	option runtime_mode 'rule'
	option sing_box_bin '/usr/bin/sing-box'
	option socket_path '/var/run/singbox-manager/singbox-managerd.sock'
	option api_listen '127.0.0.1:9090'
	option mixed_listen '0.0.0.0'
	option mixed_port '2080'
	option tproxy_port '7893'
	option dns_port '1053'
	option update_interval '24h'

config group 'home'
	option enabled '1'
	option name 'Home'
	list subscription 'example'
	option strategy 'urltest'
	option route_final 'proxy'
	option dns_final 'cloudflare_doh'
	option selected_node ''
	option health 'unknown'
	option latency_ms '0'
	option last_check ''

config subscription 'example'
	option enabled '0'
	option name 'Example'
	option url ''
	option format 'auto'
	option update_interval '24h'
	option last_update ''
	option health 'unknown'

config dns_server 'cloudflare_doh'
	option enabled '1'
	option name 'Cloudflare DoH'
	option type 'doh'
	option address 'https://1.1.1.1/dns-query'
	option detour 'proxy'

config dns_server 'cloudflare_doh_direct'
	option enabled '1'
	option name 'Cloudflare DoH (direct)'
	option type 'doh'
	option address 'https://1.1.1.1/dns-query'
	option detour 'direct'

config dns_server 'google_doh'
	option enabled '0'
	option name 'Google DoH'
	option type 'doh'
	option address 'https://dns.google/dns-query'
	option detour 'proxy'

config dns_server 'local_udp'
	option enabled '1'
	option name 'Local UDP'
	option type 'udp'
	option address '223.5.5.5'
	option detour 'direct'

config ruleset 'geoip_ir'
	option id 'geoip-ir'
	option enabled '1'
	option name 'GeoIP Iran'
	option type 'remote'
	option format 'binary'
	option url 'https://raw.githubusercontent.com/Chocolate4U/Iran-sing-box-rules/rule-set/geoip-ir.srs'
	option path '/etc/singbox-manager/rulesets/geoip-ir.srs'
	option update_interval '168h'
	option last_update ''
	option last_error ''

config ruleset 'geosite_ir'
	option id 'geosite-ir'
	option enabled '1'
	option name 'Geosite Iran'
	option type 'remote'
	option format 'binary'
	option url 'https://raw.githubusercontent.com/Chocolate4U/Iran-sing-box-rules/rule-set/geosite-ir.srs'
	option path '/etc/singbox-manager/rulesets/geosite-ir.srs'
	option update_interval '168h'
	option last_update ''
	option last_error ''

config ruleset 'geoip_cn'
	option id 'geoip-cn'
	option enabled '0'
	option name 'GeoIP China'
	option type 'remote'
	option format 'binary'
	option url 'https://raw.githubusercontent.com/SagerNet/sing-geoip/rule-set/geoip-cn.srs'
	option path '/etc/singbox-manager/rulesets/geoip-cn.srs'
	option update_interval '168h'

config ruleset 'geosite_cn'
	option id 'geosite-cn'
	option enabled '0'
	option name 'Geosite China'
	option type 'remote'
	option format 'binary'
	option url 'https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-geolocation-cn.srs'
	option path '/etc/singbox-manager/rulesets/geosite-cn.srs'
	option update_interval '168h'

config route_rule 'r10_iran_ip_direct'
	option enabled '1'
	option name 'Iran IPs direct'
	option group 'home'
	list ruleset 'geoip-ir'
	option outbound 'direct'

config route_rule 'r20_iran_site_direct'
	option enabled '1'
	option name 'Iran sites direct'
	option group 'home'
	list ruleset 'geosite-ir'
	option outbound 'direct'

config transparent 'transparent'
	option default_mode 'off'
	list lan_ifname 'br-lan'
	option dns_hijack '0'
	option kill_switch '0'

# Per-device overrides (add one section per pinned client):
# config proxy_device 'console'
# 	option enabled '1'
# 	option name 'Game console'
# 	option mac 'aa:bb:cc:dd:ee:ff'
# 	option mode 'tproxy'
# 	# Send this device's UDP directly (TCP still proxied) — good for
# 	# gaming consoles where proxied UDP breaks NAT type and adds latency.
# 	option bypass_udp '1'

config tun 'tun'
	option enabled '0'
	option auto_route '1'
	option auto_redirect '1'
	option inet4_address '172.19.0.1/30'
	option inet6_address 'fdfe:dcba:9876::1/126'
